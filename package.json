{
  "name": "react-zmage-workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "node scripts/dev-home.mjs",
    "dev:parallel": "turbo run dev --parallel",
    "dev:csr": "node scripts/dev-home.mjs",
    "dev:ssr-r19": "pnpm --filter react-zmage-demo-ssr run dev:r19",
    "dev:nextjs": "pnpm --filter react-zmage-demo-nextjs run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check": "pnpm --filter react-zmage run build && pnpm --filter react-zmage exec pnpm pack --pack-destination ../../.pack && node scripts/refresh-sandbox-tgz.mjs && pnpm install --no-frozen-lockfile && pnpm --filter \"./packages/sandbox-*\" run check && pnpm --filter \"./packages/sandbox-*\" run smoke:ssr",
    "clean": "turbo run clean",
    "publish:core": "cd packages/core && npm publish",
    "prepublishOnly": "node scripts/guard-root-publish.mjs"
  },
  "devDependencies": {
    "turbo": "^2.9.7"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10"
    }
  }
}
