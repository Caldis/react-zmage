{
  "name": "react-zmage",
  "version": "1.2.0",
  "description": "A scalable image container",
  "keywords": [
    "react",
    "image",
    "zmage",
    "zoom",
    "zoomable",
    "slidershow"
  ],
  "files": [
    "dist/"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./ssr": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ssr/index.mjs",
      "require": "./dist/ssr/index.cjs",
      "default": "./dist/ssr/index.mjs"
    },
    "./style.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Caldis/react-zmage.git",
    "directory": "packages/core"
  },
  "author": "caldis",
  "license": "MIT",
  "homepage": "https://zmage.caldis.me",
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc -p tsconfig.declarations.json",
    "build:watch": "tsup --config tsup.config.ts --watch",
    "dev": "tsup --config tsup.config.ts --watch",
    "pack": "pnpm pack --pack-destination ../../.pack",
    "lint": "pnpm lint:eslint && pnpm lint:style",
    "lint:eslint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:style": "stylelint \"src/**/*.{css,less}\"",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "postpublish": "node ../../scripts/postpublish-llms-reminder.mjs"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "react-use": "^17.6.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0 <20",
    "react-dom": ">=16.8.0 <20"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/classnames": "^2.3.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^24.1.3",
    "less": "^4.6.4",
    "postcss": "^8.5.12",
    "postcss-less": "^6.0.0",
    "postcss-modules": "^6.0.1",
    "postcss-preset-env": "^9.6.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "stylelint": "^14.16.1",
    "stylelint-config-standard": "^24.0.0",
    "tsup": "^8.5.1",
    "typescript": "^4.9.5",
    "vitest": "^3.2.4"
  }
}
